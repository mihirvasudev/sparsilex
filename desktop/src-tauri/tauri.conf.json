{
  "build": {
    "beforeBuildCommand": "cd ../web && pnpm build",
    "beforeDevCommand": "cd ../web && pnpm dev",
    "devPath": "http://localhost:3000",
    "distDir": "../web/.next"
  },
  "package": {
    "productName": "SparsileX",
    "version": "0.1.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": {
        "all": false,
        "open": true
      },
      "dialog": {
        "all": true
      },
      "fs": {
        "all": true,
        "scope": ["$APPDATA/**", "$DOCUMENT/**", "$DOWNLOAD/**"]
      }
    },
    "bundle": {
      "active": true,
      "targets": "all",
      "identifier": "com.sparsilex.app",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ]
    },
    "windows": [
      {
        "title": "SparsileX — AI-Native Statistical Analysis",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  }
}
